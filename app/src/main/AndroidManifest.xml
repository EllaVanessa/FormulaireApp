<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.formulaireapp">

    <application
        android:allowBackup="true"
        android:label="FormulaireApp"
        android:supportsRtl="true"
        android:theme="@style/Theme.FormulaireApp">

        <!-- Activity principale -->
        <activity
            android:name=".MainActivity"
            android:exported="true"> <!-- IMPORTANT 🔥 -->

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- Activity écran 2 -->
        <activity
            android:name=".Screen2Activity"
            android:exported="false"/> <!-- recommandé -->

    </application>

</manifest>